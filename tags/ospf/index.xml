</span></span><span style="display:flex;"><span>:local CFcloud &#34;false&#34;
</span></span><span style="display:flex;"><span>
</span></span><span style="display:flex;"><span>:global WANInterface &#34;[YOUR_WAN_INTERFACE_NAME]&#34;
</span></span><span style="display:flex;"><span>
</span></span><span style="display:flex;"><span>:local CFdomain &#34;[YOUR_DOMAIN]&#34;
</span></span><span style="display:flex;"><span>
